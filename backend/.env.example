# ─── Server Configuration ─────────────────────────────────────────────
PORT=5000

# ─── PostgreSQL Database Connection ────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=secureassets_db
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# ─── JWT Authentication ──────────────────────────────────────────────
# Change JWT_SECRET to a long, random, secure key in production environments
JWT_SECRET=secureassets_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=8h

# ─── CORS Cross-Origin Sharing ────────────────────────────────────────
# URL of the frontend client application
CLIENT_URL=http://localhost:5173
